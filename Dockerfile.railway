FROM node:22-bookworm

# Install git for workspace sync
RUN apt-get update && apt-get install -y git && rm -rf /var/lib/apt/lists/*

RUN corepack enable

WORKDIR /app

COPY . .

RUN pnpm install --frozen-lockfile
RUN pnpm build
RUN pnpm ui:install
RUN pnpm ui:build

# Create config/workspace directories
RUN mkdir -p /root/.clawdbot /root/clawd

ENV NODE_ENV=production
ENV HOME=/root

# Use the railway startup script
CMD ["bash", "scripts/railway-start.sh"]
