FROM node:22-bookworm

# Install git, python, ffmpeg (required for whisper)
RUN apt-get update && apt-get install -y \
    git \
    python3 \
    python3-pip \
    python3-venv \
    ffmpeg \
    && rm -rf /var/lib/apt/lists/*

# Install OpenAI Whisper CLI
RUN pip3 install --break-system-packages openai-whisper

RUN corepack enable

WORKDIR /app

COPY . .

RUN pnpm install --frozen-lockfile
RUN pnpm build
RUN pnpm ui:install
RUN pnpm ui:build

# Create config/workspace directories
RUN mkdir -p /root/.clawdbot /root/clawd

ENV NODE_ENV=production
ENV HOME=/root

# Use the railway startup script
CMD ["bash", "scripts/railway-start.sh"]
